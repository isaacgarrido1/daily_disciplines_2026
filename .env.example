# ESV API (https://api.esv.org/) – used for Scripture of the Day.
# Copy this file to .env.local and set your token.
ESV_API_TOKEN=your_esv_api_token_here

# Vercel Postgres (Neon) – syncs groups, weekly goals, and encouragements across devices.
# Add via Vercel Dashboard → Storage / Marketplace → Postgres (Neon), or set manually.
# The app uses DATABASE_URL first, then POSTGRES_URL.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
