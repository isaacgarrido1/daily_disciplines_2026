# Copy to .env.local for local development (do not commit .env.local).

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical public URL (no trailing slash). Strongly recommended on Vercel so confirmation
# emails use the correct redirect (custom domain vs *.vercel.app).
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional server-only aliases (middleware/server can read these if set):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Existing app (Neon, etc.)
# DATABASE_URL=
# POSTGRES_URL=
